{
  "expo": {
    "name": "EverlyCare",
    "slug": "everlycare",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "everlycare",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4A9BAD"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.everlycare.app",
      "infoPlist": {
        "NSCameraUsageDescription": "EverlyCare needs camera access to take photos for care recipient profiles.",
        "NSPhotoLibraryUsageDescription": "EverlyCare needs photo library access for profile avatars.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.everlycare.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4A9BAD"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "NOTIFICATIONS",
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4A9BAD"
        }
      ],
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "53a9fead-134b-442b-95c3-c7f0281cd4ee"
      }
    },
    "description": "A bilingual caregiving app for family caregivers of elderly Alzheimer's patients. Track daily care routines, medications, meals, and more.",
    "githubUrl": "https://github.com/mingcizzz/everlycare",
    "primaryColor": "#4A9BAD",
    "owner": "lanqianlong"
  }
}
