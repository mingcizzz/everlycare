{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true,
        "image": "sdk-54"
      },
      "android": {
        "image": "sdk-54",
        "buildType": "apk"
      }
    },
    "device": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "image": "sdk-54",
        "credentialsSource": "remote"
      },
      "android": {
        "image": "sdk-54",
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "image": "sdk-54",
        "credentialsSource": "remote"
      },
      "android": {
        "image": "sdk-54",
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "image": "sdk-54",
        "credentialsSource": "remote"
      },
      "android": {
        "image": "sdk-54",
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "mingchi.zhang@icloud.com",
        "appleTeamId": "ZC75YG9SY4",
        "ascAppId": "PLACEHOLDER"
      },
      "android": {
        "serviceAccountKeyPath": "./google-services-key.json",
        "track": "internal"
      }
    }
  }
}
