<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🚽 EverlyCare"
            android:textColor="#A7F3D0"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- ── NORMAL MODE ── -->
    <LinearLayout
        android:id="@+id/widget_normal_section"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_prediction_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Loading…"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:fontFamily="sans-serif-medium"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_window_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#6EE7B7"
            android:textSize="11sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- ── COUNTDOWN MODE ── -->
    <LinearLayout
        android:id="@+id/widget_countdown_section"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💧 Seated Timer"
            android:textColor="#A7F3D0"
            android:textSize="11sp" />

        <Chronometer
            android:id="@+id/widget_chronometer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:fontFamily="monospace"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- ── ACTION BAR: NORMAL MODE ── -->
    <LinearLayout
        android:id="@+id/widget_action_bar_normal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/btn_timed"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/widget_btn_bg"
            android:text="⏱ Timer"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:gravity="center"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/btn_direct"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/widget_btn_accent"
            android:text="⚡ Log"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:gravity="center"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/btn_bowel"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/widget_btn_brown"
            android:text="🚽"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:gravity="center"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/btn_fluid"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:background="@drawable/widget_btn_blue"
            android:text="💧 200ml"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:gravity="center"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- ── ACTION BAR: COUNTDOWN MODE ── -->
    <LinearLayout
        android:id="@+id/widget_action_bar_countdown"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/btn_done"
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:background="@drawable/widget_btn_green"
            android:text="✓ Done — Log Now"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:gravity="center"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

</LinearLayout>
